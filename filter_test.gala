package server

import (
    "martianoff/gala/go_builtins"
    . "martianoff/gala/test"
    . "martianoff/gala/concurrent"
    . "martianoff/gala/collection_immutable"
    "github.com/martianoff/gala-server/httpcore"
    "time"
)

// ============================================================================
// Test Helpers
// ============================================================================

func mkReq(b *httpcore.TestRequestBuilder) Request = Request(bridge = b.Build())

func req(method string, path string) *httpcore.TestRequestBuilder =
    httpcore.NewTestRequestBuilder(method, path)

// A simple handler that always returns Ok("ok")
val okHandler Handler = (r Request) => FutureOf(Ok("ok"))

// A handler that returns a JSON response
val jsonHandler Handler = (r Request) => FutureOf(JsonResponse("{\"status\": \"ok\"}"))

// A handler that panics (for testing Recovery)
val panicHandler Handler = (r Request) => Future(() => {
    go_builtins.Panic("test panic")
    return Ok("never")
})

// ============================================================================
// Logger Filter Tests
// ============================================================================

func TestLoggerDoesNotAlterResponse(t T) T {
    val r = mkReq(req("GET", "/test"))
    val resp = Logger()(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    return Eq(t1, resp.Body, "ok")
}

func TestLoggerWithFormatDoesNotAlterResponse(t T) T {
    val r = mkReq(req("GET", "/test"))
    val format = (method string, path string, status int, duration time.Duration) => s"$method $path $status"
    val resp = LoggerWithFormat(format)(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

// ============================================================================
// Recovery Filter Tests
// ============================================================================

func TestRecoveryReturns500OnPanic(t T) T {
    val r = mkReq(req("GET", "/panic"))
    val resp = Recovery()(r, panicHandler).Get()
    val t1 = Eq(t, resp.Code(), 500)
    return Contains(t1, resp.Body, "Internal Server Error")
}

func TestRecoveryPassesThroughOnSuccess(t T) T {
    val r = mkReq(req("GET", "/ok"))
    val resp = Recovery()(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

// ============================================================================
// CORS Filter Tests
// ============================================================================

func TestCorsAddsHeaders(t T) T {
    val r = mkReq(req("GET", "/test"))
    val resp = Cors()(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    val t2 = Eq(t1, resp.HeaderValue("Access-Control-Allow-Origin"), "*")
    return Contains(t2, resp.HeaderValue("Access-Control-Allow-Methods"), "GET")
}

func TestCorsOptionsPreflightReturns204(t T) T {
    val r = mkReq(req("OPTIONS", "/test"))
    val resp = Cors()(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 204)
    val t2 = Eq(t1, resp.HeaderValue("Access-Control-Allow-Origin"), "*")
    val t3 = Contains(t2, resp.HeaderValue("Access-Control-Allow-Methods"), "GET")
    return Contains(t3, resp.HeaderValue("Access-Control-Max-Age"), "86400")
}

func TestCorsWithCustomOrigin(t T) T {
    val r = mkReq(req("GET", "/test"))
    val resp = CorsWithOrigins("https://example.com")(r, okHandler).Get()
    return Eq(t, resp.HeaderValue("Access-Control-Allow-Origin"), "https://example.com")
}

func TestCorsWithConfigCustom(t T) T {
    val r = mkReq(req("GET", "/test"))
    val filter = CorsWithConfig("https://app.io", "GET, POST", "X-Custom", "3600")
    val resp = filter(r, okHandler).Get()
    val t1 = Eq(t, resp.HeaderValue("Access-Control-Allow-Origin"), "https://app.io")
    return Contains(t1, resp.HeaderValue("Access-Control-Allow-Headers"), "X-Custom")
}

// ============================================================================
// Auth Filter Tests
// ============================================================================

func TestAuthRejectsWithoutHeader(t T) T {
    val r = mkReq(req("GET", "/secret"))
    val resp = Auth()(r, okHandler).Get()
    return Eq(t, resp.Code(), 401)
}

func TestAuthAllowsWithHeader(t T) T {
    val r = mkReq(req("GET", "/secret").WithHeader("Authorization", "Bearer token"))
    val resp = Auth()(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestAuthWithValidatorAcceptsValid(t T) T {
    val validate = (header string) => header == "secret-key"
    val r = mkReq(req("GET", "/").WithHeader("Authorization", "secret-key"))
    val resp = AuthWithValidator(validate)(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestAuthWithValidatorRejectsInvalid(t T) T {
    val validate = (header string) => header == "secret-key"
    val r = mkReq(req("GET", "/").WithHeader("Authorization", "wrong"))
    val resp = AuthWithValidator(validate)(r, okHandler).Get()
    return Eq(t, resp.Code(), 401)
}

// ============================================================================
// AuthBearer Filter Tests
// ============================================================================

func TestAuthBearerAcceptsValidToken(t T) T {
    val validate = (token string) => token == "my-token"
    val r = mkReq(req("GET", "/").WithHeader("Authorization", "Bearer my-token"))
    val resp = AuthBearer(validate)(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestAuthBearerRejectsInvalidToken(t T) T {
    val validate = (token string) => token == "my-token"
    val r = mkReq(req("GET", "/").WithHeader("Authorization", "Bearer wrong"))
    val resp = AuthBearer(validate)(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.Body, "Invalid token")
}

func TestAuthBearerRejectsMissingBearer(t T) T {
    val validate = (token string) => true
    val r = mkReq(req("GET", "/").WithHeader("Authorization", "Basic abc"))
    val resp = AuthBearer(validate)(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.Body, "Missing Bearer")
}

func TestAuthBearerRejectsNoHeader(t T) T {
    val validate = (token string) => true
    val r = mkReq(req("GET", "/"))
    val resp = AuthBearer(validate)(r, okHandler).Get()
    return Eq(t, resp.Code(), 401)
}

// ============================================================================
// BasicAuth Filter Tests
// ============================================================================

func TestBasicAuthAcceptsValidCredentials(t T) T {
    val validate = (user string, pass string) => user == "admin" && pass == "secret"
    val authHeader = httpcore.EncodeBasicAuth("admin", "secret")
    val r = mkReq(req("GET", "/").WithHeader("Authorization", authHeader))
    val resp = BasicAuth(validate)(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestBasicAuthRejectsInvalidCredentials(t T) T {
    val validate = (user string, pass string) => user == "admin" && pass == "secret"
    val authHeader = httpcore.EncodeBasicAuth("admin", "wrong")
    val r = mkReq(req("GET", "/").WithHeader("Authorization", authHeader))
    val resp = BasicAuth(validate)(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.HeaderValue("WWW-Authenticate"), "Basic")
}

func TestBasicAuthRejectsMissingHeader(t T) T {
    val validate = (user string, pass string) => true
    val r = mkReq(req("GET", "/"))
    val resp = BasicAuth(validate)(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.HeaderValue("WWW-Authenticate"), "Basic")
}

func TestBasicAuthSetsUsernameInContext(t T) T {
    val validate = (user string, pass string) => true
    val authHeader = httpcore.EncodeBasicAuth("alice", "pass")
    // Use a handler that reads context to verify username was set
    val ctxHandler = (r Request) => FutureOf(
        Ok(r.CtxGet("username").GetOrElse("none")))
    val r = mkReq(req("GET", "/").WithHeader("Authorization", authHeader))
    val resp = BasicAuth(validate)(r, ctxHandler).Get()
    return Eq(t, resp.Body, "alice")
}

