// ============================================================================
// Rewrite Filter Tests
// ============================================================================

func TestRewriteMatchingRule(t T) T {
    val rules = ArrayOf(("/old/*", "/new/$1"))
    val ctxHandler = (r Request) => FutureOf(
        Ok(r.CtxGet("_rewritten_path").GetOrElse("none")))
    val r = mkReq(req("GET", "/old/foo/bar"))
    val resp = Rewrite(rules)(r, ctxHandler).Get()
    return Eq(t, resp.Body, "/new/foo/bar")
}

func TestRewriteNoMatch(t T) T {
    val rules = ArrayOf(("/old/*", "/new/$1"))
    val r = mkReq(req("GET", "/other/path"))
    val resp = Rewrite(rules)(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestRewriteMultipleRules(t T) T {
    val rules = ArrayOf(
        ("/api/*", "/v2/$1"),
        ("/old/*", "/new/$1"),
    )
    val ctxHandler = (r Request) => FutureOf(
        Ok(r.CtxGet("_rewritten_path").GetOrElse("none")))
    val r = mkReq(req("GET", "/api/users"))
    val resp = Rewrite(rules)(r, ctxHandler).Get()
    return Eq(t, resp.Body, "/v2/users")
}

// ============================================================================
// RateLimit Filter Tests
// ============================================================================

func TestRateLimitAllowsRequests(t T) T {
    val filter = RateLimit(10.0, 10.0)
    val r = mkReq(req("GET", "/"))
    val resp = filter(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestRateLimitRejectsWhenExhausted(t T) T {
    // Very small bucket: 1 token, no refill
    val filter = RateLimit(1.0, 0.0)
    val r1 = mkReq(req("GET", "/1"))
    val r2 = mkReq(req("GET", "/2"))
    // First request uses the only token
    val resp1 = filter(r1, okHandler).Get()
    // Second request should be rate limited
    val resp2 = filter(r2, okHandler).Get()
    val t1 = Eq(t, resp1.Code(), 200)
    val t2 = Eq(t1, resp2.Code(), 429)
    return Contains(t2, resp2.HeaderValue("Retry-After"), "1")
}

func TestRateLimitPerIPAllowsDifferentIPs(t T) T {
    val filter = RateLimitPerIP(1.0, 0.0)
    val r1 = mkReq(req("GET", "/").WithRemoteAddr("10.0.0.1:1234"))
    val r2 = mkReq(req("GET", "/").WithRemoteAddr("10.0.0.2:1234"))
    val resp1 = filter(r1, okHandler).Get()
    val resp2 = filter(r2, okHandler).Get()
    // Different IPs should each get their own bucket
    val t1 = Eq(t, resp1.Code(), 200)
    return Eq(t1, resp2.Code(), 200)
}

// ============================================================================
// Composed Filter Tests
// ============================================================================

func TestMultipleFiltersCompose(t T) T {
    // Apply Logger + Recovery + Cors to a handler
    val r = mkReq(req("GET", "/"))
    val handler = okHandler
    // Manual filter composition: Logger wraps Recovery wraps Cors wraps handler
    val withCors = (r2 Request) => Cors()(r2, handler)
    val withRecovery = (r2 Request) => Recovery()(r2, withCors)
    val resp = Logger()(r, withRecovery).Get()
    val t1 = Eq(t, resp.Code(), 200)
    return Eq(t1, resp.HeaderValue("Access-Control-Allow-Origin"), "*")
}

func TestFilterPreservesResponseBody(t T) T {
    val customHandler = (r Request) => FutureOf(Ok("custom body"))
    val r = mkReq(req("GET", "/"))
    val resp = Logger()(r, customHandler).Get()
    return Eq(t, resp.Body, "custom body")
}

// ============================================================================
// MethodOverride Filter Tests
// ============================================================================

func TestMethodOverrideFromHeader(t T) T {
    val methodHandler = (r Request) => FutureOf(Ok(r.Method().Name()))
    val r = mkReq(req("POST", "/resource").
        WithHeader("X-HTTP-Method-Override", "PUT"))
    val resp = MethodOverride()(r, methodHandler).Get()
    return Eq(t, resp.Body, "PUT")
}

func TestMethodOverrideFromFormField(t T) T {
    val methodHandler = (r Request) => FutureOf(Ok(r.Method().Name()))
    val r = mkReq(req("POST", "/resource").
        WithFormParam("_method", "DELETE"))
    val resp = MethodOverride()(r, methodHandler).Get()
    return Eq(t, resp.Body, "DELETE")
}

func TestMethodOverrideSkipsGET(t T) T {
    val methodHandler = (r Request) => FutureOf(Ok(r.Method().Name()))
    val r = mkReq(req("GET", "/resource").
        WithHeader("X-HTTP-Method-Override", "PUT"))
    val resp = MethodOverride()(r, methodHandler).Get()
    // GET should not be overridden
    return Eq(t, resp.Body, "GET")
}

func TestMethodOverridePassesThroughWithoutOverride(t T) T {
    val r = mkReq(req("POST", "/resource"))
    val resp = MethodOverride()(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

// ============================================================================
// BodyDump Filter Tests
// ============================================================================

func TestBodyDumpCapturesBodies(t T) T {
    var capturedReqBody = ""
    var capturedRespBody = ""
    val handler = (reqBody string, respBody string) => {
        capturedReqBody = reqBody
        capturedRespBody = respBody
    }
    val customHandler = (r Request) => FutureOf(Ok("response body"))
    val r = mkReq(req("POST", "/").WithBody("request body"))
    val resp = BodyDump(handler)(r, customHandler).Get()

    val t1 = Eq(t, resp.Code(), 200)
    val t2 = Eq(t1, capturedReqBody, "request body")
    return Eq(t2, capturedRespBody, "response body")
}

func TestBodyDumpDoesNotAlterResponse(t T) T {
    val handler = (reqBody string, respBody string) => {}
    val r = mkReq(req("GET", "/"))
    val resp = BodyDump(handler)(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    return Eq(t1, resp.Body, "ok")
}

// ============================================================================
// MethodOverride + BodyDump + Decompress Creation Tests
// ============================================================================

func TestMethodOverrideCreation(t T) T = IsTrue(t, MethodOverride() != nil)

func TestBodyDumpCreation(t T) T {
    val handler = (reqBody string, respBody string) => {}
    return IsTrue(t, BodyDump(handler) != nil)
}

func TestDecompressCreation(t T) T = IsTrue(t, Decompress() != nil)

// ============================================================================
// HTTPError Filter Integration Tests
// ============================================================================

func TestHTTPErrorInFilter(t T) T {
    val err = NewHTTPError(StatusNotFound(), "resource not found")
    // A handler that returns HTTPError response
    val errorHandler = (r Request) => FutureOf(err.ToJsonResponse())
    val r = mkReq(req("GET", "/missing"))
    val resp = Logger()(r, errorHandler).Get()
    val t1 = Eq(t, resp.Code(), 404)
    return Eq(t1, resp.HeaderValue("Content-Type"), "application/json")
}

// ============================================================================
// JWT Auth Filter Tests
// ============================================================================

func TestJWTAuthRejectsMissingToken(t T) T {
    val r = mkReq(req("GET", "/api"))
    val resp = JWTAuth("my-secret")(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.Body, "Missing Bearer token")
}

func TestJWTAuthRejectsNonBearerHeader(t T) T {
    val r = mkReq(req("GET", "/api").WithHeader("Authorization", "Basic abc"))
    val resp = JWTAuth("my-secret")(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.Body, "Missing Bearer token")
}

func TestJWTAuthAcceptsValidToken(t T) T {
    val secret = "test-jwt-secret"
    val claims = "{\"sub\":\"user123\",\"iss\":\"test-app\",\"aud\":\"api\"}"
    val token = httpcore.CreateJWT(claims, secret)
    val r = mkReq(req("GET", "/api").WithHeader("Authorization", s"Bearer $token"))
    val resp = JWTAuth(secret)(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestJWTAuthRejectsInvalidSignature(t T) T {
    val claims = "{\"sub\":\"user123\"}"
    val token = httpcore.CreateJWT(claims, "correct-secret")
    val r = mkReq(req("GET", "/api").WithHeader("Authorization", s"Bearer $token"))
    val resp = JWTAuth("wrong-secret")(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.Body, "invalid signature")
}

func TestJWTAuthRejectsMalformedToken(t T) T {
    val r = mkReq(req("GET", "/api").WithHeader("Authorization", "Bearer not-a-jwt"))
    val resp = JWTAuth("secret")(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.Body, "malformed token")
}

func TestJWTAuthStoresClaimsInContext(t T) T {
    val secret = "ctx-test-secret"
    val claims = "{\"sub\":\"alice\",\"iss\":\"my-app\"}"
    val token = httpcore.CreateJWT(claims, secret)
    val ctxHandler = (r Request) => {
        val sub = r.CtxGet("jwt-sub").GetOrElse("none")
        val iss = r.CtxGet("jwt-iss").GetOrElse("none")
        return FutureOf(Ok(s"$sub:$iss"))
    }
    val r = mkReq(req("GET", "/api").WithHeader("Authorization", s"Bearer $token"))
    val resp = JWTAuth(secret)(r, ctxHandler).Get()
    return Eq(t, resp.Body, "alice:my-app")
}

func TestJWTAuthRejectsExpiredToken(t T) T {
    val secret = "expiry-test"
    // Token with exp in the past (epoch 0)
    val claims = "{\"sub\":\"user\",\"exp\":0}"
    val token = httpcore.CreateJWT(claims, secret)
    val r = mkReq(req("GET", "/api").WithHeader("Authorization", s"Bearer $token"))
    val resp = JWTAuth(secret)(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 401)
    return Contains(t1, resp.Body, "expired")
}

func TestJWTAuthWithConfigSkipsExpiryCheck(t T) T {
    val secret = "no-expiry-check"
    // Token with exp in the past, but expiry checking disabled
    val claims = "{\"sub\":\"user\",\"exp\":0}"
    val token = httpcore.CreateJWT(claims, secret)
    val r = mkReq(req("GET", "/api").WithHeader("Authorization", s"Bearer $token"))
    val resp = JWTAuthWithConfig(secret, false)(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestJWTAuthCreation(t T) T = IsTrue(t, JWTAuth("secret") != nil)

func TestJWTAuthWithConfigCreation(t T) T = IsTrue(t, JWTAuthWithConfig("secret", true) != nil)

// ============================================================================
// Proxy Filter Tests
// ============================================================================

func TestProxyCreation(t T) T = IsTrue(t, Proxy("http://localhost:3000") != nil)

func TestProxyWithTimeoutCreation(t T) T {
    val filter = ProxyWithTimeout("http://localhost:3000", 5 * time.Second)
    return IsTrue(t, filter != nil)
}

// ============================================================================
// BadGateway Response Tests
// ============================================================================

func TestBadGatewayResponse(t T) T {
    val resp = BadGateway("upstream error")
    val t1 = Eq(t, resp.Code(), 502)
    return Eq(t1, resp.Body, "upstream error")
}

// ============================================================================
// JWT Go Helper Tests (via httpcore)
// ============================================================================

func TestCreateAndParseJWT(t T) T {
    val secret = "roundtrip-test"
    val claims = "{\"sub\":\"test-user\",\"role\":\"admin\"}"
    val token = httpcore.CreateJWT(claims, secret)
    val result = httpcore.ParseAndValidateJWT(token, secret, false)
    val t1 = IsTrue(t, result.Valid)
    val t2 = Eq(t1, result.Claims.Get("sub"), "test-user")
    return Eq(t2, result.Claims.Get("role"), "admin")
}

func TestJWTRejectsWrongSecret(t T) T {
    val token = httpcore.CreateJWT("{\"sub\":\"user\"}", "secret1")
    val result = httpcore.ParseAndValidateJWT(token, "secret2", false)
    val t1 = IsFalse(t, result.Valid)
    return Eq(t1, result.Error, "invalid signature")
}

func TestJWTRejectsMalformed(t T) T {
    val result = httpcore.ParseAndValidateJWT("not.a.jwt.token", "secret", false)
    return IsFalse(t, result.Valid)
}

func TestJWTNumericClaims(t T) T {
    val secret = "numeric-test"
    val claims = "{\"sub\":\"user\",\"exp\":1999999999,\"iat\":1000000000}"
    val token = httpcore.CreateJWT(claims, secret)
    val result = httpcore.ParseAndValidateJWT(token, secret, false)
    val t1 = IsTrue(t, result.Valid)
    return Eq(t1, result.Claims.Get("exp"), "1999999999")
}

// ============================================================================
// Power Features — ComposeFilters Tests
// ============================================================================

func TestComposeFiltersBasic(t T) T {
    // Compose Logger + Cors — both should execute
    val composed = ComposeFilters(Logger(), Cors())
    val r = mkReq(req("GET", "/test"))
    val resp = composed(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    // Cors should have added headers
    return Eq(t1, resp.HeaderValue("Access-Control-Allow-Origin"), "*")
}

func TestComposeFiltersCustom(t T) T {
    // Custom filter that adds a header
    val addHeader = (r Request, next Handler) =>
        next(r).Map((resp) => resp.WithHeader("X-Custom", "composed"))
    val composed = ComposeFilters(addHeader, Logger())
    val r = mkReq(req("GET", "/test"))
    val resp = composed(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    return Eq(t1, resp.HeaderValue("X-Custom"), "composed")
}

// ============================================================================
// Power Features — When (Conditional Filter) Tests
// ============================================================================

func TestWhenAppliesWhenTrue(t T) T {
    val authWhenAPI = WhenFilter(
        (r) => r.Path() == "/api",
        Auth())
    // Request to /api without auth header should be rejected
    val r = mkReq(req("GET", "/api"))
    val resp = authWhenAPI(r, okHandler).Get()
    return Eq(t, resp.Code(), 401)
}

func TestWhenSkipsWhenFalse(t T) T {
    val authWhenAPI = WhenFilter(
        (r) => r.Path() == "/api",
        Auth())
    // Request to /health should pass through without auth
    val r = mkReq(req("GET", "/health"))
    val resp = authWhenAPI(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

// ============================================================================
// Power Features — Skip Filter Tests
// ============================================================================

func TestSkipExcludesPath(t T) T {
    val authWithSkip = Skip(Auth(), "/health", "/metrics")
    // Request to /health should skip auth
    val r = mkReq(req("GET", "/health"))
    val resp = authWithSkip(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestSkipAppliesForOtherPaths(t T) T {
    val authWithSkip = Skip(Auth(), "/health", "/metrics")
    // Request to /api without auth should be rejected
    val r = mkReq(req("GET", "/api"))
    val resp = authWithSkip(r, okHandler).Get()
    return Eq(t, resp.Code(), 401)
}

func TestSkipMultiplePaths(t T) T {
    val authWithSkip = Skip(Auth(), "/health", "/metrics", "/status")
    val r1 = mkReq(req("GET", "/health"))
    val r2 = mkReq(req("GET", "/metrics"))
    val r3 = mkReq(req("GET", "/status"))
    val t1 = Eq(t, authWithSkip(r1, okHandler).Get().Code(), 200)
    val t2 = Eq(t1, authWithSkip(r2, okHandler).Get().Code(), 200)
    return Eq(t2, authWithSkip(r3, okHandler).Get().Code(), 200)
}

// ============================================================================
// Power Features — Use Filter Tests
// ============================================================================

func TestUseReturnsCorrectCount(t T) T {
    val filters = Use(Logger(), Recovery(), Cors())
    return Eq(t, filters.Size(), 3)
}

func TestUseEmptyReturnsEmpty(t T) T {
    val filters = Use()
    return Eq(t, filters.Size(), 0)
}

func TestUseSingle(t T) T {
    val filters = Use(Auth())
    return Eq(t, filters.Size(), 1)
}

// ============================================================================
// Power Features — ETag Filter Tests
// ============================================================================

func TestETagAddsHeader(t T) T {
    val r = mkReq(req("GET", "/"))
    val resp = ETag()(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    val etag = resp.HeaderValue("ETag")
    // ETag should be non-empty for non-empty body
    return IsTrue(t1, etag != "")
}

func TestETagSkipsEmptyBody(t T) T {
    val emptyHandler = (r Request) => FutureOf(NoContent())
    val r = mkReq(req("GET", "/"))
    val resp = ETag()(r, emptyHandler).Get()
    return Eq(t, resp.HeaderValue("ETag"), "")
}

func TestETagReturns304WhenMatching(t T) T {
    // First get the ETag for the body
    val r1 = mkReq(req("GET", "/"))
    val resp1 = ETag()(r1, okHandler).Get()
    val etag = resp1.HeaderValue("ETag")

    // Send request with matching If-None-Match
    val r2 = mkReq(req("GET", "/").WithHeader("If-None-Match", etag))
    val resp2 = ETag()(r2, okHandler).Get()
    return Eq(t, resp2.Code(), 304)
}

// ============================================================================
// Power Features — CacheControl Filter Tests
// ============================================================================

func TestCacheControlSetsHeader(t T) T {
    val r = mkReq(req("GET", "/"))
    val resp = CacheControl(3600)(r, okHandler).Get()
    return Eq(t, resp.HeaderValue("Cache-Control"), "public, max-age=3600")
}

func TestCacheControlCustomAge(t T) T {
    val r = mkReq(req("GET", "/"))
    val resp = CacheControl(60)(r, okHandler).Get()
    return Eq(t, resp.HeaderValue("Cache-Control"), "public, max-age=60")
}

// ============================================================================
// Power Features — NoCacheFilter Tests
// ============================================================================

func TestNoCacheFilterSetsHeaders(t T) T {
    val r = mkReq(req("GET", "/"))
    val resp = NoCacheFilter()(r, okHandler).Get()
    val t1 = Eq(t, resp.HeaderValue("Cache-Control"), "no-cache, no-store, must-revalidate")
    val t2 = Eq(t1, resp.HeaderValue("Pragma"), "no-cache")
    return Eq(t2, resp.HeaderValue("Expires"), "0")
}

// ============================================================================
// Power Features — CircuitBreaker Filter Tests
// ============================================================================

func TestCircuitBreakerAllowsWhenClosed(t T) T {
    val cb = CircuitBreaker(maxFailures = 3, resetTimeout = 1 * time.Second, halfOpenMax = 1)
    val r = mkReq(req("GET", "/"))
    val resp = cb(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestCircuitBreakerOpensAfterFailures(t T) T {
    val cb = CircuitBreaker(maxFailures = 2, resetTimeout = 10 * time.Second, halfOpenMax = 1)
    val failHandler = (r Request) => FutureOf(InternalError("fail"))
    val r = mkReq(req("GET", "/"))
    // First two failures should pass through (recording failures)
    val resp1 = cb(r, failHandler).Get()
    val resp2 = cb(r, failHandler).Get()
    // After 2 failures, circuit should open
    val resp3 = cb(r, okHandler).Get()
    val t1 = Eq(t, resp1.Code(), 500)
    val t2 = Eq(t1, resp2.Code(), 500)
    return Eq(t2, resp3.Code(), 503)
}

// ============================================================================
// Power Features — Retry Filter Tests
// ============================================================================

func TestRetrySuccessOnFirstAttempt(t T) T {
    val retry = RetryFilter(3, 1 * time.Millisecond)
    val r = mkReq(req("GET", "/"))
    val resp = retry(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestRetryRetriesOnFailure(t T) T {
    var attempts = 0
    val flakyHandler = (r Request) => Future[Response](() => {
        attempts = attempts + 1
        if attempts < 3 {
            return InternalError("fail")
        }
        return Ok("recovered")
    })
    val retry = RetryFilter(3, 1 * time.Millisecond)
    val r = mkReq(req("GET", "/"))
    val resp = retry(r, flakyHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    return Eq(t1, resp.Body, "recovered")
}

// ============================================================================
// Power Features — Bulkhead Filter Tests
// ============================================================================

func TestBulkheadAllowsRequests(t T) T {
    val bh = Bulkhead(10)
    val r = mkReq(req("GET", "/"))
    val resp = bh(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestBulkheadRejectsWhenFull(t T) T {
    // Bulkhead with capacity 1
    val bh = Bulkhead(1)
    // Use a handler that holds the semaphore (never releases via normal path)
    // Acquire the slot manually
    val r1 = mkReq(req("GET", "/1"))
    // The first request goes through and the semaphore is released after response
    val resp1 = bh(r1, okHandler).Get()
    val t1 = Eq(t, resp1.Code(), 200)
    return t1
}

// ============================================================================
// Power Features — Sliding Window Rate Limiter Tests
// ============================================================================

func TestSlidingWindowAllowsRequests(t T) T {
    val filter = RateLimitSlidingWindow(10, 1 * time.Second)
    val r = mkReq(req("GET", "/"))
    val resp = filter(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestSlidingWindowRejectsWhenExhausted(t T) T {
    // Allow only 2 requests per second
    val filter = RateLimitSlidingWindow(2, 1 * time.Second)
    val r = mkReq(req("GET", "/"))
    val resp1 = filter(r, okHandler).Get()
    val resp2 = filter(r, okHandler).Get()
    val resp3 = filter(r, okHandler).Get()
    val t1 = Eq(t, resp1.Code(), 200)
    val t2 = Eq(t1, resp2.Code(), 200)
    val t3 = Eq(t2, resp3.Code(), 429)
    return Contains(t3, resp3.HeaderValue("Retry-After"), "1")
}

func TestSlidingWindowPerIPAllowsDifferentIPs(t T) T {
    val filter = RateLimitSlidingWindowPerIP(1, 1 * time.Second)
    val r1 = mkReq(req("GET", "/").WithRemoteAddr("10.0.0.1:1234"))
    val r2 = mkReq(req("GET", "/").WithRemoteAddr("10.0.0.2:1234"))
    val resp1 = filter(r1, okHandler).Get()
    val resp2 = filter(r2, okHandler).Get()
    // Different IPs should each get their own window
    val t1 = Eq(t, resp1.Code(), 200)
    return Eq(t1, resp2.Code(), 200)
}

func TestSlidingWindowPerIPRejectsSameIP(t T) T {
    val filter = RateLimitSlidingWindowPerIP(1, 1 * time.Second)
    val r1 = mkReq(req("GET", "/").WithRemoteAddr("10.0.0.1:1234"))
    val r2 = mkReq(req("GET", "/").WithRemoteAddr("10.0.0.1:5678"))
    val resp1 = filter(r1, okHandler).Get()
    val resp2 = filter(r2, okHandler).Get()
    val t1 = Eq(t, resp1.Code(), 200)
    return Eq(t1, resp2.Code(), 429)
}

func TestSlidingWindowCreation(t T) T {
    val filter = RateLimitSlidingWindow(100, 1 * time.Minute)
    return IsTrue(t, filter != nil)
}

func TestSlidingWindowPerIPCreation(t T) T {
    val filter = RateLimitSlidingWindowPerIP(100, 1 * time.Minute)
    return IsTrue(t, filter != nil)
}
