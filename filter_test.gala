func TestKeyAuthRejectsMissingKey(t T) T {
    val validate = (key string) => true
    val r = mkReq(req("GET", "/"))
    val resp = KeyAuth("header:X-API-Key", validate)(r, okHandler).Get()
    return Eq(t, resp.Code(), 401)
