// ============================================================================
// Secure Filter Tests
// ============================================================================

func TestSecureAddsDefaultHeaders(t T) T {
    val r = mkReq(req("GET", "/"))
    val resp = Secure()(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    val t2 = Eq(t1, resp.HeaderValue("X-XSS-Protection"), "1; mode=block")
    val t3 = Eq(t2, resp.HeaderValue("X-Content-Type-Options"), "nosniff")
    return Eq(t3, resp.HeaderValue("X-Frame-Options"), "SAMEORIGIN")
}

func TestSecureWithConfigCustomHeaders(t T) T {
    val r = mkReq(req("GET", "/"))
    val filter = SecureWithConfig("0", "nosniff", "DENY", 31536000, "default-src 'self'", "no-referrer")
    val resp = filter(r, okHandler).Get()
    val t1 = Eq(t, resp.HeaderValue("X-XSS-Protection"), "0")
    val t2 = Eq(t1, resp.HeaderValue("X-Frame-Options"), "DENY")
    val t3 = Contains(t2, resp.HeaderValue("Strict-Transport-Security"), "31536000")
    val t4 = Eq(t3, resp.HeaderValue("Content-Security-Policy"), "default-src 'self'")
    return Eq(t4, resp.HeaderValue("Referrer-Policy"), "no-referrer")
}

func TestSecureSkipsEmptyValues(t T) T {
    val r = mkReq(req("GET", "/"))
    val filter = SecureWithConfig("", "", "", 0, "", "")
    val resp = filter(r, okHandler).Get()
    val t1 = Eq(t, resp.HeaderValue("X-XSS-Protection"), "")
    val t2 = Eq(t1, resp.HeaderValue("X-Content-Type-Options"), "")
    return Eq(t2, resp.HeaderValue("X-Frame-Options"), "")
}

// ============================================================================
// BodyLimit Filter Tests
// ============================================================================

func TestBodyLimitAllowsSmallBody(t T) T {
    val r = mkReq(req("POST", "/").WithBody("small"))
    val resp = BodyLimit("1M")(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestBodyLimitRejectsLargeBody(t T) T {
    // Create a body larger than 10 bytes
    val largeBody = "12345678901"
    val r = mkReq(req("POST", "/").WithBody(largeBody))
    val resp = BodyLimitBytes(10)(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 413)
    return Contains(t1, resp.Body, "Request Entity Too Large")
}

func TestBodyLimitBytesExactBoundary(t T) T {
    val body = "1234567890"
    val r = mkReq(req("POST", "/").WithBody(body))
    // Exactly 10 bytes should pass (not exceed)
    val resp = BodyLimitBytes(10)(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestBodyLimitParsesUnits(t T) T {
    // 1K = 1024 bytes, body is small
    val r = mkReq(req("POST", "/").WithBody("hello"))
    val resp = BodyLimit("1K")(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

// ============================================================================
// RequestId Filter Tests
// ============================================================================

func TestRequestIdAddsHeader(t T) T {
    val r = mkReq(req("GET", "/"))
    val filter = RequestId()
    val resp = filter(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 200)
    val reqId = resp.HeaderValue("X-Request-ID")
    return HasPrefix(t1, reqId, "req-")
}

func TestRequestIdIncrementsCounter(t T) T {
    val filter = RequestId()
    val r1 = mkReq(req("GET", "/1"))
    val r2 = mkReq(req("GET", "/2"))
    val resp1 = filter(r1, okHandler).Get()
    val resp2 = filter(r2, okHandler).Get()
    val id1 = resp1.HeaderValue("X-Request-ID")
    val id2 = resp2.HeaderValue("X-Request-ID")
    // IDs should be different
    return IsTrue(t, id1 != id2)
}

func TestRequestIdSetsContext(t T) T {
    val filter = RequestId()
    val ctxHandler = (r Request) => FutureOf(
        Ok(r.CtxGet("request-id").GetOrElse("none")))
    val r = mkReq(req("GET", "/"))
    val resp = filter(r, ctxHandler).Get()
    return HasPrefix(t, resp.Body, "req-")
}

// ============================================================================
// Gzip Filter Tests
// ============================================================================

func TestGzipAddsHeadersWhenAccepted(t T) T {
    val r = mkReq(req("GET", "/").WithHeader("Accept-Encoding", "gzip, deflate"))
    val resp = Gzip()(r, okHandler).Get()
    val t1 = Eq(t, resp.HeaderValue("Content-Encoding"), "gzip")
    return Eq(t1, resp.HeaderValue("Vary"), "Accept-Encoding")
}

func TestGzipSkipsWhenNotAccepted(t T) T {
    val r = mkReq(req("GET", "/"))
    val resp = Gzip()(r, okHandler).Get()
    return Eq(t, resp.HeaderValue("Content-Encoding"), "")
}

func TestGzipSkipsEmptyBody(t T) T {
    val emptyHandler = (r Request) => FutureOf(NoContent())
    val r = mkReq(req("GET", "/").WithHeader("Accept-Encoding", "gzip"))
    val resp = Gzip()(r, emptyHandler).Get()
    return Eq(t, resp.HeaderValue("Content-Encoding"), "")
}

// ============================================================================
// CSRF Filter Tests
// ============================================================================

func TestCSRFSkipsGET(t T) T {
    val r = mkReq(req("GET", "/"))
    val resp = CSRF("secret")(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestCSRFSkipsHEAD(t T) T {
    val r = mkReq(req("HEAD", "/"))
    val resp = CSRF("secret")(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestCSRFSkipsOPTIONS(t T) T {
    val r = mkReq(req("OPTIONS", "/"))
    val resp = CSRF("secret")(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestCSRFSetsCookieOnGET(t T) T {
    val r = mkReq(req("GET", "/"))
    val resp = CSRF("secret")(r, okHandler).Get()
    // Should set a _csrf cookie
    val hasCookie = resp.Cookies.Exists((c) => c.Name == "_csrf")
    return IsTrue(t, hasCookie)
}

func TestCSRFRejectsPOSTWithoutToken(t T) T {
    val r = mkReq(req("POST", "/submit"))
    val resp = CSRF("secret")(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 403)
    return Contains(t1, resp.Body, "CSRF")
}

func TestCSRFAcceptsPOSTWithValidToken(t T) T {
    val filter = CSRF("test-secret")
    // Step 1: GET to obtain token
    val getReq = mkReq(req("GET", "/"))
    val getResp = filter(getReq, okHandler).Get()
    val csrfCookie = getResp.Cookies.Find((c) => c.Name == "_csrf")
    val token = csrfCookie.Map((c) => c.Value).GetOrElse("")

    // Step 2: POST with the token in X-CSRF-Token header
    val postReq = mkReq(req("POST", "/submit").WithHeader("X-CSRF-Token", token))
    val postResp = filter(postReq, okHandler).Get()
    return Eq(t, postResp.Code(), 200)
}

// ============================================================================
// HTTPSRedirect Filter Tests
// ============================================================================

func TestHTTPSRedirectOnHTTP(t T) T {
    val r = mkReq(req("GET", "/page").WithScheme("http").WithHost("example.com"))
    val resp = HTTPSRedirect()(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 301)
    return Eq(t1, resp.HeaderValue("Location"), "https://example.com/page")
}

func TestHTTPSRedirectSkipsHTTPS(t T) T {
    val r = mkReq(req("GET", "/page").WithScheme("https").WithHost("example.com"))
    val resp = HTTPSRedirect()(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

func TestHTTPSRedirectPreservesQuery(t T) T {
    val r = mkReq(req("GET", "/page").
        WithScheme("http").
        WithHost("example.com").
        WithRawQuery("q=test"))
    val resp = HTTPSRedirect()(r, okHandler).Get()
    return Eq(t, resp.HeaderValue("Location"), "https://example.com/page?q=test")
}

// ============================================================================
// WWWRedirect Filter Tests
// ============================================================================

func TestWWWRedirectAddsWWW(t T) T {
    val r = mkReq(req("GET", "/page").WithHost("example.com"))
    val resp = WWWRedirect()(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 301)
    return Contains(t1, resp.HeaderValue("Location"), "www.example.com")
}

func TestWWWRedirectSkipsWWW(t T) T {
    val r = mkReq(req("GET", "/page").WithHost("www.example.com"))
    val resp = WWWRedirect()(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

// ============================================================================
// NonWWWRedirect Filter Tests
// ============================================================================

func TestNonWWWRedirectRemovesWWW(t T) T {
    val r = mkReq(req("GET", "/page").WithHost("www.example.com"))
    val resp = NonWWWRedirect()(r, okHandler).Get()
    val t1 = Eq(t, resp.Code(), 301)
    val t2 = Contains(t1, resp.HeaderValue("Location"), "example.com")
    // Should NOT have www.
    return NotContains(t2, resp.HeaderValue("Location"), "www.")
}

func TestNonWWWRedirectSkipsNonWWW(t T) T {
    val r = mkReq(req("GET", "/page").WithHost("example.com"))
    val resp = NonWWWRedirect()(r, okHandler).Get()
    return Eq(t, resp.Code(), 200)
}

