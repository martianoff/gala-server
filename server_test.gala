// ============================================================================
// Power Features — Response.copy() Builder Tests
// ============================================================================

func TestResponseCopyWithHeader(t T) T {
    val r1 = Ok("hello")
    val r2 = r1.WithHeader("X-Test", "value")
    val t1 = Eq(t, r1.HeaderValue("X-Test"), "")
    return Eq(t1, r2.HeaderValue("X-Test"), "value")
}

func TestResponseCopyWithBody(t T) T {
    val r1 = Ok("original")
    val r2 = r1.WithBody("updated")
    val t1 = Eq(t, r1.Body, "original")
    return Eq(t1, r2.Body, "updated")
}

func TestResponseCopyWithStatus(t T) T {
    val r1 = Ok("hello")
    val r2 = r1.WithStatus(StatusNotFound())
    val t1 = Eq(t, r1.Code(), 200)
    return Eq(t1, r2.Code(), 404)
}

func TestResponseCopyChained(t T) T {
    val resp = Ok("original").
        WithBody("updated").
        WithHeader("X-A", "1").
        WithStatus(StatusCreated())
    val t1 = Eq(t, resp.Body, "updated")
    val t2 = Eq(t1, resp.HeaderValue("X-A"), "1")
    return Eq(t2, resp.Code(), 201)
}
