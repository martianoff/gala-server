// ============================================================================
// Route Naming Tests
// ============================================================================

func TestServerNamed(t T) T {
    val s = NewServer().
        GET("/users", (req) => Ok("users")).Named("user-list").
        GET("/users/{id}", (req) => Ok("user")).Named("user-detail")
    return Eq(t, s.RouteCount(), 2)
}

func TestServerURLGeneration(t T) T {
    val s = NewServer().
        GET("/users", (req) => Ok("users")).Named("user-list").
        GET("/users/{id}", (req) => Ok("user")).Named("user-detail")
    val t1 = IsSome(t, s.URL("user-list"))
    val t2 = Eq(t1, s.URL("user-list").Get(), "/users")
    val t3 = Eq(t2, s.URL("user-detail", "id", "42").Get(), "/users/42")
    return IsNone(t3, s.URL("missing"))
}

// ============================================================================
// Server Renderer/Validator Config Tests
// ============================================================================

func TestServerRenderWithoutRenderer(t T) T {
    val s = NewServer()
    val resp = s.Render("template", nil)
    return Eq(t, resp.Code(), 500)
}

// ============================================================================
// Full Framework Configuration Test
// ============================================================================

func TestFullFrameworkConfiguration(t T) T {
    val api = NewGroup().
        GET("/users", (req) => Ok("users")).
        POST("/users", (req) => Created("ok")).
        WithFilter(Auth())

    val admin = NewGroup().
        GET("/stats", (req) => Ok("stats")).
        WithFilter(AuthBearer((token) => token == "admin"))

    val s = NewServer().
        WithName("Full API").
        WithPort(9090).
        WithShutdownTimeout(15 * time.Second).
        WithDebug(true).
        WithBanner(false).
        WithErrorHandler((err) => JsonResponse(s"{\"error\": \"$err\"}")).
        WithNotFound((req) => NotFound("custom 404")).
        GET("/", (req) => Ok("Hello, GALA!")).
        GET("/health", (req) => JsonResponse("{\"status\": \"ok\"}")).
        Static("/public/", "./static").
        Group("/api/v1", api).
        Group("/admin", admin).
        WithFilter(Logger()).
        WithFilter(Recovery()).
        WithFilter(Cors()).
        WithFilter(RateLimit(1000.0, 100.0)).
        WithFilter(RequestId())

    val t1 = Eq(t, s.Port, 9090)
    val t2 = Eq(t1, s.Name, "Full API")
    val t3 = IsTrue(t2, s.Debug)
    val t4 = IsFalse(t3, s.Banner)
    val t5 = Eq(t4, s.RouteCount(), 5)
    return Eq(t5, s.FilterCount(), 5)
}

// ============================================================================
// Power Features — BasePath Tests
// ============================================================================

func TestWithBasePath(t T) T {
    val s = NewServer().WithBasePath("/api/v1")
    return Eq(t, s.BasePath, "/api/v1")
}

func TestBasePathDefault(t T) T {
    val s = NewServer()
    return Eq(t, s.BasePath, "")
}

func TestBasePathPreservedAcrossBuilderCalls(t T) T {
    val s = NewServer().
        WithBasePath("/api/v1").
        WithPort(9090).
        GET("/users", (req) => Ok("users"))
    val t1 = Eq(t, s.BasePath, "/api/v1")
    val t2 = Eq(t1, s.Port, 9090)
    return Eq(t2, s.RouteCount(), 1)
}

func TestBasePathWithRoutes(t T) T {
    val s = NewServer().
        WithBasePath("/api/v1").
        GET("/users", (req) => Ok("users")).
        POST("/items", (req) => Created("ok"))
    val routes = s.Routes()
    val t1 = Eq(t, routes.Size(), 2)
    return Eq(t1, s.BasePath, "/api/v1")
}

