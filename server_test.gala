}

func TestToMethodUnknown(t T) T {
    val m = toMethod("PURGE")
    return Eq(t, m.Name(), "PURGE")
}

func TestToMethodKnown(t T) T {
    val t1 = Eq(t, toMethod("GET").Name(), "GET")
    val t2 = Eq(t1, toMethod("POST").Name(), "POST")
    val t3 = Eq(t2, toMethod("PUT").Name(), "PUT")
    val t4 = Eq(t3, toMethod("DELETE").Name(), "DELETE")
    val t5 = Eq(t4, toMethod("PATCH").Name(), "PATCH")
    val t6 = Eq(t5, toMethod("HEAD").Name(), "HEAD")
    return Eq(t6, toMethod("OPTIONS").Name(), "OPTIONS")
}

