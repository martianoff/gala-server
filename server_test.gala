func TestNegotiateJson(t T) T {
    val r = buildReq(testReq("GET", "/").WithHeader("Accept", "application/json"))
    val resp = Negotiate(r,
        () => JsonResponse("{\"ok\":true}"),
        () => Html("<p>ok</p>"),
        () => Text("ok"))
    val t1 = Eq(t, resp.Code(), 200)
    return Eq(t1, resp.HeaderValue("Content-Type"), "application/json")
}

func TestNegotiateHtml(t T) T {
    val r = buildReq(testReq("GET", "/").WithHeader("Accept", "text/html"))
