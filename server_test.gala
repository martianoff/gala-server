func TestStatusTooManyRequestsCode(t T) T =
    Eq(t, StatusTooManyRequests().Code(), 429)

func TestStatusRequestTimeoutCode(t T) T =
    Eq(t, StatusRequestTimeout().Code(), 408)

func TestStatusBadGatewayCode(t T) T =
    Eq(t, StatusBadGateway().Code(), 502)

func TestExtendedStatusCodeValues(t T) T {
    val t1 = Eq(t, StatusUnprocessableEntity().Code(), 422)
    val t2 = Eq(t1, StatusTooManyRequests().Code(), 429)
    val t3 = Eq(t2, StatusRequestTimeout().Code(), 408)
    return Eq(t3, StatusBadGateway().Code(), 502)
}

